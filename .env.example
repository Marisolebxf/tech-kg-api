# 图数据库连接配置
# GRAPH_DB_BACKEND 可选值: neo4j | trs_graph (默认 trs_graph)
GRAPH_DB_BACKEND=trs_graph

# --- Neo4j 配置 (GRAPH_DB_BACKEND=neo4j 时生效) ---
# GRAPH_DB_URI=bolt://localhost:7687
# GRAPH_DB_USERNAME=neo4j
# GRAPH_DB_PASSWORD=
# GRAPH_DB_DATABASE=neo4j

# --- TRS Graph 配置 (GRAPH_DB_BACKEND=trs_graph 时生效) ---
# URI 为 trs-graph-service 的地址 (IP:端口)
GRAPH_DB_URI=http://localhost:8090
# DATABASE 为 TRS Graph 图空间名称
GRAPH_DB_DATABASE=entity_binding_demo
# TRS_GRAPH_API_KEY=your_api_key_here

GRAPH_DB_MAX_CONNECTION_POOL_SIZE=50
GRAPH_DB_CONNECTION_TIMEOUT=30

# --- 语义召回 / MySQL 绑定数据源 ---
# 开启后，init-data 会优先从 MySQL 读取 scholar / paper / paper_author / venue 数据
SEMANTIC_MATCHING_ENABLED=true
SEMANTIC_MATCHING_USE_MYSQL=false
# 示例：mysql+pymysql://root:password@127.0.0.1:3306/techkg?charset=utf8mb4
SEMANTIC_MATCHING_MYSQL_URL=
SEMANTIC_MATCHING_MODEL=moka-ai/m3e-small
SEMANTIC_MATCHING_TOP_K=3
SEMANTIC_MATCHING_MIN_SCORE=0.55
# FAISS 召回配置：hnsw 为 ANN，flat 为精确内积召回
SEMANTIC_MATCHING_FAISS_BACKEND=hnsw
SEMANTIC_MATCHING_FAISS_HNSW_M=32
SEMANTIC_MATCHING_FAISS_HNSW_EF_CONSTRUCTION=200
SEMANTIC_MATCHING_FAISS_HNSW_EF_SEARCH=64
SEMANTIC_MATCHING_FAISS_OVERSAMPLE=3

# --- 专家关系 Demo 缓存 ---
# 定时刷新专家关系展示数据到 Redis；若 Redis 不可用，则自动回退到内存快照和现场生成
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 专家关系缓存刷新周期（秒）
EXPERT_DIRECT_CACHE_REFRESH_SECONDS=300
# Redis 连接失败后的重试间隔（秒）
EXPERT_DIRECT_REDIS_RETRY_SECONDS=60
# 缓存写入 Redis 的 TTL（秒）
EXPERT_DIRECT_CACHE_TTL_SECONDS=1800

# --- 抽取任务状态缓存 ---
# 抽取任务元数据/结果写入 Redis；若 Redis 不可用，则回退到内存
EXTRACTION_TASK_REDIS_URL=redis://127.0.0.1:6379/0
EXTRACTION_TASK_REDIS_PREFIX=techkg:extraction:task
EXTRACTION_TASK_FLUSH_SECONDS=30
EXTRACTION_TASK_REDIS_RETRY_SECONDS=60
EXTRACTION_TASK_TTL_SECONDS=86400

# --- 抽取任务后台 worker ---
# worker 定时从 Redis / 内存队列取任务并执行写库
EXTRACTION_JOB_REDIS_URL=redis://127.0.0.1:6379/0
EXTRACTION_JOB_REDIS_KEY=techkg:extraction:jobs
EXTRACTION_JOB_POLL_SECONDS=5
EXTRACTION_JOB_REDIS_RETRY_SECONDS=60
EXTRACTION_JOB_TTL_SECONDS=86400
