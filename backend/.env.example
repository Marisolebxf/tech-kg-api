# App
APP_ENV=dev
SERVER_PORT=8000

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=techkg
MYSQL_USERNAME=root
MYSQL_PASSWORD=123456789

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# TRSGraph (HTTP REST via trs-graph-service, fronts NebulaGraph)
TRS_GRAPH_BASE_URL=http://localhost:8090
TRS_GRAPH_SPACE=techkg
TRS_GRAPH_API_KEY=
TRS_GRAPH_TIMEOUT=30

# Kafka
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_CONSUMER_GROUP=techkg

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# LLM
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
MODEL=glm-5.1
LLM_API_KEY=${ZHIPUAI_API_KEY}
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=${MODEL}
