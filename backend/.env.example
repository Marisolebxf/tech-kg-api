# ============================================
# 智谱AI配置 (用于实体抽取和GraphRAG问答)
# ============================================
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
MODEL=glm-5.1

# ============================================
# 图数据库连接配置
# GRAPH_DB_BACKEND 可选值: neo4j | trs_graph (默认 trs_graph)
# ============================================
GRAPH_DB_BACKEND=trs_graph

# --- Neo4j 配置 (GRAPH_DB_BACKEND=neo4j 时生效) ---
# GRAPH_DB_URI=bolt://localhost:7687  # Docker环境使用 bolt://neo4j:7687
# GRAPH_DB_USERNAME=neo4j
# GRAPH_DB_PASSWORD=your_neo4j_password_here
# GRAPH_DB_DATABASE=neo4j

# --- TRS Graph 配置 (GRAPH_DB_BACKEND=trs_graph 时生效) ---
# URI 为 trs-graph-service 的地址 (IP:端口)
GRAPH_DB_URI=http://localhost:8090
# DATABASE 为 TRS Graph 图空间名称
GRAPH_DB_DATABASE=tech-kg
# AUTH 为 TRS Graph API Key (请求头 X-API-Key)
GRAPH_DB_AUTH=ysukeg

GRAPH_DB_MAX_CONNECTION_POOL_SIZE=50
GRAPH_DB_CONNECTION_TIMEOUT=30

# ============================================
# LLM配置 (用于关系抽取等)
# ============================================
LLM_API_KEY=${ZHIPUAI_API_KEY}  # 默认使用智谱API Key
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=${MODEL}  # 默认使用智谱模型
