# App
APP_ENV=dev
SERVER_PORT=8000

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=techkg
MYSQL_USERNAME=root
MYSQL_PASSWORD=123456789

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# TRSGraph
GRAPH_DB_BACKEND=trsgraph
TRSGRAPH_HOST=127.0.0.1
TRSGRAPH_PORT=9669
TRSGRAPH_USERNAME=root
TRSGRAPH_PASSWORD=trsadmin
TRSGRAPH_SPACE=techkg
GRAPH_DB_MAX_CONNECTION_POOL_SIZE=50
GRAPH_DB_CONNECTION_TIMEOUT=30

# Kafka
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_CONSUMER_GROUP=techkg

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# LLM
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
MODEL=glm-5.1
LLM_API_KEY=${ZHIPUAI_API_KEY}
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=${MODEL}
